// Prisma schema for SushiStats / food-tracker-api
// docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UnitType {
  gram
  piece
  ml
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  avatarUrl    String?  @map("avatar_url")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  createdFoods     Food[]
  foodEntries      FoodEntry[]
  foodUpvotes      FoodUpvote[]
  createdGroups    Group[]
  groupMemberships GroupMember[]
  groupVotes       GroupVote[]
  groupMessages    GroupMessage[]
  messageReactions GroupMessageReaction[]
  userStatistics   UserStatistics[]

  @@map("users")
}

model Food {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  calories        Int // per 100g
  protein         Decimal  @db.Decimal(10, 2) // g per 100g
  carbs           Decimal  @db.Decimal(10, 2)
  fat             Decimal  @db.Decimal(10, 2)
  description     String?
  category        String?
  imageUrl        String?  @map("image_url")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  upvotes         Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy    User              @relation(fields: [createdByUserId], references: [id])
  foodEntries  FoodEntry[]
  upvotedBy    FoodUpvote[]
  groupVotes   GroupVote[]
  groupWinners GroupVoteWinner[]

  @@index([createdByUserId])
  @@map("foods")
}

model FoodEntry {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  foodId    String   @map("food_id") @db.Uuid
  quantity  Decimal  @db.Decimal(10, 2)
  unit      UnitType
  eatenAt   DateTime @map("eaten_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id])

  @@index([userId, eatenAt])
  @@map("food_entries")
}

model FoodUpvote {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  foodId    String   @map("food_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  food Food @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([userId, foodId])
  @@map("food_upvotes")
}

model Group {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  avatarUrl       String?  @map("avatar_url")
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  isPrivate       Boolean  @default(false) @map("is_private")
  maxMembers      Int?     @map("max_members")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  createdBy  User              @relation(fields: [createdByUserId], references: [id])
  members    GroupMember[]
  votes      GroupVote[]
  winners    GroupVoteWinner[]
  messages   GroupMessage[]
  statistics GroupStatistics[]

  @@index([createdByUserId])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId  String   @map("group_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@map("group_members")
}

model GroupVote {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId  String   @map("group_id") @db.Uuid
  foodId   String   @map("food_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  votedAt  DateTime @default(now()) @map("voted_at")
  voteDate DateTime @map("vote_date") @db.Date

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  food  Food  @relation(fields: [foodId], references: [id])
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId, voteDate])
  @@index([groupId, voteDate])
  @@map("group_votes")
}

model GroupVoteWinner {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId    String   @map("group_id") @db.Uuid
  foodId     String   @map("food_id") @db.Uuid
  winnerDate DateTime @map("winner_date") @db.Date
  voteCount  Int      @map("vote_count")
  createdAt  DateTime @default(now()) @map("created_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  food  Food  @relation(fields: [foodId], references: [id])

  @@unique([groupId, winnerDate])
  @@index([groupId, winnerDate])
  @@map("group_vote_winners")
}

model GroupMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  text      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group     Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions GroupMessageReaction[]

  @@index([groupId, createdAt])
  @@map("group_messages")
}

model GroupMessageReaction {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("group_message_reactions")
}

model UserStatistics {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  date          DateTime @db.Date
  totalCalories Int      @map("total_calories")
  totalProtein  Decimal  @map("total_protein") @db.Decimal(10, 2)
  totalCarbs    Decimal  @map("total_carbs") @db.Decimal(10, 2)
  totalFat      Decimal  @map("total_fat") @db.Decimal(10, 2)
  entriesCount  Int      @map("entries_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("user_statistics")
}

model GroupStatistics {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  groupId       String   @map("group_id") @db.Uuid
  date          DateTime @db.Date
  totalCalories Int      @map("total_calories")
  totalProtein  Decimal  @map("total_protein") @db.Decimal(10, 2)
  totalCarbs    Decimal  @map("total_carbs") @db.Decimal(10, 2)
  totalFat      Decimal  @map("total_fat") @db.Decimal(10, 2)
  entriesCount  Int      @map("entries_count")
  membersCount  Int      @map("members_count")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, date])
  @@index([groupId, date])
  @@map("group_statistics")
}
